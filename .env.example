# Earth33 Survival — API Keys
# Copy this file to .env and fill in your keys.
# Only the provider(s) you plan to use need a key.

# Gemini (primary provider, used by default)
GEMINI_API_KEY=

# OpenAI (fallback if Gemini quota is exhausted)
OPENAI_API_KEY=

# Anthropic (optional alternative provider)
ANTHROPIC_API_KEY=
